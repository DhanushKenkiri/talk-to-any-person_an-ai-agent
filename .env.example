# Talk To Any Person - Persona Report & Q&A (HITL)

# --- AI provider ---
# This repo supports either:
# - An OpenAI-compatible HTTP API (recommended for portability)
# - AWS Bedrock (optional)
# - Or no LLM (fallback mode: produces an evidence inventory)
LLM_PROVIDER=openai_compatible

# OpenAI-compatible API (set these when LLM_PROVIDER=openai_compatible)
AI_API_BASE_URL=
AI_API_KEY=
AI_MODEL=

# AWS Bedrock (set these when LLM_PROVIDER=bedrock)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
BEDROCK_MODEL=amazon.nova-pro-v1:0

SEARCH_RESULTS=18
NEWS_RESULTS=10
SCRAPE_LIMIT=14
REQUEST_TIMEOUT=12

# --- Masumi payment/registry ---
# Required when DEV_MODE=false
PAYMENT_SERVICE_URL=
PAYMENT_API_KEY=
REGISTRY_API_URL=
REGISTRY_API_KEY=
SELLER_VKEY=
AGENT_IDENTIFIER=
NETWORK=Preprod
AGENT_NAME=Talk To Any Person - Persona Report & Q&A (HITL)
CAPABILITY_NAME=talktoanyperson
PRICE_PER_REQUEST=5
TOKEN_UNIT=16a55b2a349361ff88c03788f93e1e966e5d689605d044fef722ddde0014df10745553444d
ENDPOINT=
HOST=0.0.0.0
PORT=8080
DEV_MODE=true



